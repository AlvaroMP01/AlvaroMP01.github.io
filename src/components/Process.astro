---
import { home } from '../i18n/home';
import type { Locale } from '../i18n/ui';

interface Props {
  locale: Locale;
  sectionId: string;
}

const { locale, sectionId } = Astro.props;
const t = home[locale].process;
---

<section id={sectionId} class="border-b border-line py-13 md:py-[72px]">
  <div class="mx-auto max-w-site px-5 md:px-8">
    <div class="mb-10 flex flex-wrap items-end justify-between gap-6">
      <h2 class="max-w-[18ch] font-disp text-[clamp(26px,3.2vw,38px)] font-semibold leading-[1.05] tracking-tight">{t.heading}</h2>
      <span class="self-start pt-2 font-mono text-xs uppercase tracking-[0.1em] text-muted">{t.kicker}</span>
    </div>

    <div class="grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-line bg-line md:grid-cols-4">
      {t.steps.map((step) => (
        <div class="flex min-h-[190px] flex-col gap-3 bg-surface p-6">
          <span class="font-mono text-xs text-ac">{step.n}</span>
          <h4 class="font-disp text-lg font-semibold">{step.title}</h4>
          <p class="text-[13.5px] text-muted">{step.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>
