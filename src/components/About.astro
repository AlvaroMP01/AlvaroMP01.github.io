---
import { home } from '../i18n/home';
import type { Locale } from '../i18n/ui';

interface Props {
  locale: Locale;
  sectionId: string;
}

const { locale, sectionId } = Astro.props;
const t = home[locale].about;
---

<section id={sectionId} class="border-b border-line py-13 md:py-[72px]">
  <div class="mx-auto max-w-site px-5 md:px-8">
    <div class="mb-10 flex flex-wrap items-end justify-between gap-6">
      <h2 class="max-w-[18ch] font-disp text-[clamp(26px,3.2vw,38px)] font-semibold leading-[1.05] tracking-tight">{t.heading}</h2>
      <span class="self-start pt-2 font-mono text-xs uppercase tracking-[0.1em] text-muted">{t.kicker}</span>
    </div>

    <div class="grid grid-cols-1 items-start gap-8 md:grid-cols-[1.1fr_1fr] md:gap-12">
      <div>
        {t.bio.map((p) => (
          <p class="mb-4 max-w-[46ch] text-lg text-muted">{p}</p>
        ))}

        <div class="mt-6 flex flex-col gap-2.5">
          {t.credentials.map((c) => {
            const Tag = c.href ? 'a' : 'div';
            return (
              <Tag
                href={c.href}
                {...(c.href ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
                class:list={[
                  'group flex items-center gap-3.5 rounded-xl border border-line bg-surface p-4',
                  { 'border-ac bg-[color-mix(in_oklab,var(--ac)_7%,var(--surface))]': c.highlight },
                  { 'transition-colors hover:border-ink': c.href }
                ]}
              >
                <span class="grid h-[38px] w-[38px] flex-none place-items-center rounded-[9px] bg-raised text-ac">
                  <svg viewBox="0 0 24 24" width="19" height="19" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M12 2l2.4 5 5.6.6-4.2 3.7 1.2 5.5L12 19.5 7 16.8l1.2-5.5L4 7.6 9.6 7z"></path></svg>
                </span>
                <div class="min-w-0 flex-1">
                  <b class="block text-[14.5px] font-semibold">{c.title}</b>
                  <span class="text-[13px] text-muted">{c.detail}</span>
                </div>
                {c.href && (
                  <span class="ml-auto flex flex-none items-center gap-1 font-mono text-[12px] text-muted transition-colors group-hover:text-ink">
                    {t.viewLabel}
                    <span aria-hidden="true">↗</span>
                  </span>
                )}
              </Tag>
            );
          })}
        </div>
      </div>

      <div class="flex flex-col gap-[22px]">
        {t.skills.map((group) => (
          <div>
            <div class="mb-3 flex items-center gap-2.5">
              <span class="font-mono text-xs uppercase tracking-[0.1em] text-ink">{group.group}</span>
              <span class="ml-auto font-mono text-[11px] text-faint">{group.count}</span>
            </div>
            <div class="flex flex-wrap gap-1.5">
              {group.items.map((item) => (
                <span class="whitespace-nowrap rounded-lg border border-line bg-surface px-3 py-1.5 text-[13px] text-ink">{item}</span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
