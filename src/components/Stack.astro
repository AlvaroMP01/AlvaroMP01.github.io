---
import { home } from '../i18n/home';
import type { Locale } from '../i18n/ui';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = home[locale].hero;
const stack = home[locale].stack;
---

<div class="flex flex-wrap items-center gap-2">
  <span class="mr-1 font-mono text-xs uppercase tracking-[0.1em] text-muted">{t.stackLabel}</span>
  {stack.map((item) => (
    <span class="whitespace-nowrap rounded-[7px] border border-line bg-surface px-[11px] py-1.5 font-mono text-xs text-muted">{item}</span>
  ))}
</div>
