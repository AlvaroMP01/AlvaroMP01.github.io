---
import { home } from '../i18n/home';
import type { Locale } from '../i18n/ui';

interface Props {
  locale: Locale;
  sectionId: string;
}

const { locale, sectionId } = Astro.props;
const t = home[locale].contact;

const CONTACT_EMAIL = 'alvaromorcillo2001@gmail.com';
const GITHUB_URL = 'https://github.com/AlvaroMP01';
const LINKEDIN_URL = 'https://www.linkedin.com/in/alvaromorcillo-dev/';
---

<section id={sectionId} class="py-13 md:py-[72px]">
  <div class="mx-auto grid max-w-site grid-cols-1 items-start gap-8 px-5 md:grid-cols-2 md:gap-12 md:px-8">
    <div>
      <span class="mb-3.5 inline-block font-mono text-xs uppercase tracking-[0.1em] text-muted">{t.kicker}</span>
      <h2 class="mb-4 max-w-[14ch] font-disp text-[clamp(30px,4vw,48px)] font-semibold leading-[1.05] tracking-tight">{t.heading}</h2>
      <p class="mb-6 max-w-[42ch] text-lg text-muted">{t.lead}</p>

      <div class="flex flex-col gap-2.5">
        {/* Primary working contact: real mailto, opens the visitor's mail client. */}
        <a class="flex items-center gap-3.5 rounded-[11px] border border-line bg-surface p-4 transition-colors hover:border-ink" href={`mailto:${CONTACT_EMAIL}`}>
          <svg class="h-5 w-5 text-muted" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="2" y="4" width="20" height="16" rx="2"></rect><path d="m2 7 10 6 10-6"></path></svg>
          <span class="flex min-w-0 flex-1 flex-col">
            <b class="whitespace-nowrap text-sm font-medium">{t.emailLabel}</b>
            <span class="truncate font-mono text-[12.5px] text-muted">{CONTACT_EMAIL}</span>
          </span>
          <span class="ml-auto font-mono text-faint" aria-hidden="true">→</span>
        </a>

        <a class="flex items-center gap-3.5 rounded-[11px] border border-line bg-surface p-4 transition-colors hover:border-ink" href={GITHUB_URL} target="_blank" rel="noopener noreferrer">
          <svg class="h-5 w-5 text-muted" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.5 2 2 6.6 2 12.3c0 4.5 2.9 8.3 6.8 9.7.5.1.7-.2.7-.5v-1.7c-2.8.6-3.4-1.4-3.4-1.4-.4-1.2-1.1-1.5-1.1-1.5-.9-.6.1-.6.1-.6 1 .1 1.5 1 1.5 1 .9 1.6 2.4 1.1 3 .9.1-.7.3-1.1.6-1.4-2.2-.3-4.6-1.1-4.6-5 0-1.1.4-2 1-2.7-.1-.3-.4-1.3.1-2.7 0 0 .8-.3 2.7 1a9.3 9.3 0 0 1 5 0c1.9-1.3 2.7-1 2.7-1 .5 1.4.2 2.4.1 2.7.6.7 1 1.6 1 2.7 0 3.9-2.3 4.7-4.6 5 .4.3.7.9.7 1.9v2.8c0 .3.2.6.7.5 3.9-1.4 6.8-5.2 6.8-9.7C22 6.6 17.5 2 12 2Z"></path></svg>
          <span class="flex min-w-0 flex-1 flex-col">
            <b class="whitespace-nowrap text-sm font-medium">{t.githubLabel}</b>
            <span class="truncate font-mono text-[12.5px] text-muted">github.com/AlvaroMP01</span>
          </span>
          <span class="ml-auto font-mono text-faint" aria-hidden="true">→</span>
        </a>

        <a class="flex items-center gap-3.5 rounded-[11px] border border-line bg-surface p-4 transition-colors hover:border-ink" href={LINKEDIN_URL} target="_blank" rel="noopener noreferrer">
          <svg class="h-5 w-5 text-muted" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-4 0v7h-4v-7a6 6 0 0 1 6-6z"></path><rect x="2" y="9" width="4" height="12"></rect><circle cx="4" cy="4" r="2"></circle></svg>
          <span class="flex min-w-0 flex-1 flex-col">
            <b class="whitespace-nowrap text-sm font-medium">{t.linkedinLabel}</b>
            <span class="truncate font-mono text-[12.5px] text-muted">linkedin.com/in/alvaromorcillo-dev</span>
          </span>
          <span class="ml-auto font-mono text-faint" aria-hidden="true">→</span>
        </a>

        {/* "Descargar CV" / "Download CV" omitted: no public/CV.pdf yet. Phase 7: add CV.pdf and reinstate this contact method. */}
      </div>
    </div>

    <form
      id="contact-form"
      action="https://api.web3forms.com/submit"
      method="POST"
      class="flex flex-col gap-3.5 rounded-2xl border border-line bg-surface p-6"
    >
      <input type="hidden" name="access_key" value="0d2bf6fe-63df-4a4a-9903-db8a8903ef1b" />
      <input type="hidden" name="subject" value="Nuevo mensaje desde el portfolio" />
      <input type="hidden" name="from_name" value="Portfolio · alvaromp01.github.io" />
      {/* Honeypot — hidden from people; bots tick it and Web3Forms drops the submission. */}
      <label class="hidden" aria-hidden="true">
        <input type="checkbox" name="botcheck" tabindex="-1" autocomplete="off" />
      </label>

      <div class="flex flex-col gap-1.5">
        <label class="font-mono text-[11px] uppercase tracking-[0.06em] text-muted" for="contact-name">{t.formName}</label>
        <input id="contact-name" name="name" type="text" required placeholder={t.formNamePh} class="rounded-[9px] border border-line bg-bg px-3.5 py-2.5 text-[15px] text-ink transition-colors focus:border-ac focus:outline-none" />
      </div>
      <div class="flex flex-col gap-1.5">
        <label class="font-mono text-[11px] uppercase tracking-[0.06em] text-muted" for="contact-email">Email</label>
        <input id="contact-email" name="email" type="email" required placeholder={t.formEmailPh} class="rounded-[9px] border border-line bg-bg px-3.5 py-2.5 text-[15px] text-ink transition-colors focus:border-ac focus:outline-none" />
      </div>
      <div class="flex flex-col gap-1.5">
        <label class="font-mono text-[11px] uppercase tracking-[0.06em] text-muted" for="contact-message">{t.formMessage}</label>
        <textarea id="contact-message" name="message" rows="4" required placeholder={t.formMessagePh} class="resize-vertical rounded-[9px] border border-line bg-bg px-3.5 py-2.5 text-[15px] text-ink transition-colors focus:border-ac focus:outline-none"></textarea>
      </div>
      <button type="submit" class="inline-flex items-center justify-center gap-2 rounded-lg border border-ink bg-ink px-[18px] py-2.5 text-sm font-medium text-bg transition-opacity hover:opacity-90 disabled:opacity-60">
        <span data-form-label>{t.formSubmit}</span>
        <span class="font-mono" aria-hidden="true">→</span>
      </button>
      <p data-form-status role="status" aria-live="polite" class="font-mono text-[13px] text-muted" hidden></p>
    </form>

    <script is:inline define:vars={{ msgSending: t.formSending, msgOk: t.formSuccess, msgErr: t.formError, msgSubmit: t.formSubmit }}>
      (function () {
        var form = document.getElementById('contact-form');
        if (!form) return;
        var statusEl = form.querySelector('[data-form-status]');
        var labelEl = form.querySelector('[data-form-label]');
        var btn = form.querySelector('button[type="submit"]');
        form.addEventListener('submit', function (e) {
          e.preventDefault();
          if (labelEl) labelEl.textContent = msgSending;
          if (btn) btn.disabled = true;
          statusEl.hidden = true;
          fetch('https://api.web3forms.com/submit', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
            body: JSON.stringify(Object.fromEntries(new FormData(form)))
          })
            .then(function (r) { return r.json(); })
            .then(function (json) {
              if (json && json.success) {
                statusEl.textContent = msgOk;
                statusEl.style.color = 'oklch(0.6 0.15 150)';
                form.reset();
              } else {
                statusEl.textContent = msgErr;
                statusEl.style.color = 'var(--ink)';
              }
            })
            .catch(function () {
              statusEl.textContent = msgErr;
              statusEl.style.color = 'var(--ink)';
            })
            .finally(function () {
              statusEl.hidden = false;
              if (btn) btn.disabled = false;
              if (labelEl) labelEl.textContent = msgSubmit;
            });
        });
      })();
    </script>
  </div>
</section>
