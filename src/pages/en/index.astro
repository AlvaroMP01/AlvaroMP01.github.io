---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import FeaturedProjects from '../../components/FeaturedProjects.astro';
import About from '../../components/About.astro';
import Process from '../../components/Process.astro';
import Contact from '../../components/Contact.astro';
import { ui } from '../../i18n/ui';

const locale = 'en';
const strings = ui[locale];
---

<BaseLayout
  title="Álvaro Morcillo — Fullstack Developer"
  description="Álvaro Morcillo's portfolio, fullstack developer. Projects, stack and contact."
  locale={locale}
  altUrl="/"
>
  <Hero locale={locale} projectsHref={strings.nav.projects.href} />
  <FeaturedProjects locale={locale} sectionId="projects" />
  <About locale={locale} sectionId="about" />
  <Process locale={locale} sectionId="process" />
  <Contact locale={locale} sectionId="contact" />
</BaseLayout>
