---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Álvaro Morcillo — Fullstack Developer"
  description="Álvaro Morcillo's portfolio, fullstack developer. Projects, stack and contact."
  locale="en"
  altUrl="/"
>
  <section class="mx-auto max-w-site px-5 py-16 md:px-8 md:py-24">
    <h1 class="max-w-[16ch] font-disp text-[clamp(38px,8.5vw,80px)] font-semibold leading-[1.05] tracking-tight">
      I build product from <span class="text-ac">end to end.</span>
    </h1>
    <p class="mt-4 max-w-[54ch] text-lg text-muted">
      Frontend, backend and data with the same judgement. The full home lands in phase 5.
    </p>
  </section>
</BaseLayout>
